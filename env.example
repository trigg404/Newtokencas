# Use a SEPARATE bot and chat from your other scanners — that is the
# entire point of deploying this one on its own.
TELEGRAM_BOT_TOKEN=your_separate_bot_token
TELEGRAM_CHAT_ID=your_separate_chat_id

# ── Feed A: GeckoTerminal new pools ──────────────────────────────────
POLL_MINUTES=5
MIN_LIQUIDITY_USD=5000
MAX_AGE_HOURS=6
MIN_VOL_LIQ_RATIO=0.5
CHAINS=eth,base,solana,bsc,arbitrum

# ── Feed B: pump.fun (free WebSocket via PumpPortal) ─────────────────
ENABLE_PUMPFUN=true
# Optional — the free new-token subscription works without a key too
PUMPPORTAL_API_KEY=
PUMPFUN_MIN_INITIAL_BUY_SOL=1

# ── Safety check: GoPlus Security (free, no key needed) ──────────────
# Automatic for eth/base/bsc/arbitrum. Solana not yet automated.

# ── New: buy pressure + holder growth confirmation ────────────────────
MIN_BUY_SELL_RATIO=3
MIN_HOLDER_GROWTH_PCT=0.10
MAX_WATCH_MINUTES=45

# ── New: pump.fun quality mode + Solana safety checking ───────────────
# "creation" = earliest, noisiest. "migration" = only alert once a token
# graduates to a real pool (~$69k proven demand) — far fewer alerts, much
# higher quality. "both" sends both, clearly labeled.
PUMPFUN_ALERT_ON=migration
# RugCheck.xyz safety check runs automatically on all pump.fun alerts,
# free, no key needed — no config required.
